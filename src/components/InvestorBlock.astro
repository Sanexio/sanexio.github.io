---
// Investor block — traction metrics + roadmap gates + a focused CTA.
// Light surface section that frames Sanexio as an investable health-AI play.

interface Stat {
  value: string;
  label: string;
}

const stats: Stat[] = [
  { value: '5 Phasen', label: 'DHT-Entwicklung von der Anamnese bis zum eigenen Health-LLM' },
  { value: '14B', label: 'eigenes Health-LLM-Basismodell, on-prem statt fremder API' },
  { value: 'Phase-2-KI', label: 'live: Avatar erklärt den Verlauf und antwortet im Chat' },
  { value: 'iOS · Web', label: 'native App mit echter HealthKit-Anbindung, live auf dem Gerät' },
];

interface Gate {
  id: string;
  label: string;
  body: string;
  state: 'done' | 'now' | 'next';
  stateLabel: string;
}

const gates: Gate[] = [
  { id: 'd0-d2', label: 'D0–D2', body: 'Twin-Datenmodell, RAG-Kette, Zeitreihen-Tools & Guardrails. Frontend→Backend→Modell bewiesen.', state: 'done', stateLabel: 'Abgeschlossen' },
  { id: 'eval', label: 'Eval & Governance', body: 'Synthetische Eval-Fälle mit Ground-Truth, ehrliche Baseline, DSGVO-Rahmen (Art. 9).', state: 'done', stateLabel: 'Abgeschlossen' },
  { id: 'phase2', label: 'Phase-2-KI', body: 'Avatar erklärt & chattet live über das deployte Backend. iOS on-device, gehärteter KI-Chat.', state: 'now', stateLabel: 'Live jetzt' },
  { id: 'd3', label: 'D3 · Daten', body: 'Anonymisierte/einwilligungsbasierte Praxisdaten — nur nach Governance-Freigabe.', state: 'next', stateLabel: 'Gated' },
  { id: 'd4', label: 'D4 · Fine-Tune', body: 'Medizinfähiges Modell auf GPU-VM via Distillation nachtrainieren & einklinken.', state: 'next', stateLabel: 'Gated' },
  { id: 'd5', label: 'D5 · Klinik', body: 'Klinische Validierung, bevor irgendetwas patientennah genutzt wird.', state: 'next', stateLabel: 'Gated' },
];
---

<section class="sx-inv sx-section" id="investoren">
  <div class="sx-container">
    <p class="sx-eyebrow sx-inv__eyebrow">Für Investoren</p>
    <h2 class="sx-title-1 sx-inv__heading">
      Health-AI mit Substanz — eigenes Modell, eigene Daten-Standards.
    </h2>
    <p class="sx-body-lg sx-prose sx-inv__lead">
      Sanexio verbindet klinische Tiefe mit einer eigenen KI-Plattform. Wir bauen
      gegen die härtesten Anforderungen des Gesundheitsmarkts — Daten-Governance
      und klinische Sicherheit — und überspringen keinen Schritt.
    </p>

    <div class="sx-inv__stats">
      {stats.map((s) => (
        <div class="sx-inv__stat">
          <span class="sx-inv__stat-value">{s.value}</span>
          <span class="sx-inv__stat-label">{s.label}</span>
        </div>
      ))}
    </div>

    <p class="sx-inv__roadmap-label">Roadmap — jede Phase ein prüfbares Gate</p>
    <ol class="sx-inv__gates" aria-label="Roadmap-Phasen">
      {gates.map((g) => (
        <li class={`sx-inv__gate is-${g.state}`}>
          <span class="sx-inv__gate-dot" aria-hidden="true"></span>
          <p class="sx-inv__gate-label">{g.label}</p>
          <p class="sx-inv__gate-body">{g.body}</p>
          <span class={`sx-inv__gate-state is-${g.state}`}>{g.stateLabel}</span>
        </li>
      ))}
    </ol>

    <div class="sx-inv__cta">
      <div>
        <h3 class="sx-title-3 sx-inv__cta-title">Lass uns über die Zukunft der Prävention sprechen.</h3>
        <p class="sx-inv__cta-body">
          Wir suchen Partner und Investoren, die Health-AI mit echter Substanz bauen wollen.
        </p>
      </div>
      <a class="sx-btn sx-btn-primary" href="mailto:s.stracke@sanexio.de?subject=Investoren-Interesse%20Sanexio%20DHT">
        Kontakt aufnehmen →
      </a>
    </div>
  </div>
</section>

<style>
  .sx-inv {
    background: var(--sx-c-bg-soft);
    color: var(--sx-c-ink);
  }

  .sx-inv__eyebrow { color: var(--sx-c-accent); }

  .sx-inv__heading {
    color: var(--sx-c-ink);
    max-width: 44rem;
    margin: 0.75rem 0 1.25rem;
  }

  .sx-inv__lead {
    color: var(--sx-c-ink-muted);
    margin: 0 0 3rem;
  }

  /* Stats */
  .sx-inv__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .sx-inv__stat {
    background: var(--sx-c-surface);
    border: 1px solid var(--sx-c-line);
    border-radius: var(--sx-radius-card);
    padding: 1.5rem 1.5rem 1.625rem;
  }

  .sx-inv__stat-value {
    display: block;
    font-family: var(--sx-font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    letter-spacing: -0.02em;
    color: var(--sx-c-ink);
    margin-bottom: 0.4rem;
  }

  .sx-inv__stat-label {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--sx-c-ink-muted);
  }

  /* Roadmap gates */
  .sx-inv__roadmap-label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--sx-c-ink-muted);
    margin: 0 0 1.5rem;
  }

  .sx-inv__gates {
    list-style: none;
    margin: 0 0 3.5rem;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  .sx-inv__gate {
    position: relative;
    background: var(--sx-c-surface);
    border: 1px solid var(--sx-c-line);
    border-radius: var(--sx-radius-card);
    padding: 1.375rem 1.5rem 1.5rem 2.5rem;
  }

  .sx-inv__gate-dot {
    position: absolute;
    left: 1.25rem;
    top: 1.7rem;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--sx-c-line);
    border: 2px solid var(--sx-c-ink-muted);
  }

  .sx-inv__gate.is-done .sx-inv__gate-dot {
    background: var(--sx-c-data-hi);
    border-color: var(--sx-c-data-hi);
  }

  .sx-inv__gate.is-now .sx-inv__gate-dot {
    background: var(--sx-c-accent);
    border-color: var(--sx-c-accent);
    box-shadow: 0 0 0 4px rgba(193, 18, 31, 0.18);
  }

  .sx-inv__gate-label {
    font-family: var(--sx-font-display);
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--sx-c-ink);
    margin: 0 0 0.3rem;
  }

  .sx-inv__gate-body {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--sx-c-ink-muted);
    margin: 0 0 0.6rem;
  }

  .sx-inv__gate-state {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .sx-inv__gate-state.is-done { color: var(--sx-c-data); }
  .sx-inv__gate-state.is-now { color: var(--sx-c-accent); }
  .sx-inv__gate-state.is-next { color: var(--sx-c-ink-muted); }

  /* CTA */
  .sx-inv__cta {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
    background: var(--sx-c-bg-brand);
    color: var(--sx-c-ink-on-brand);
    border-radius: var(--sx-radius-xl, 24px);
    padding: 2.5rem 2rem;
  }

  .sx-inv__cta-title { color: var(--sx-c-ink-on-brand); margin: 0 0 0.5rem; }
  .sx-inv__cta-body { color: rgba(255, 255, 255, 0.78); margin: 0; font-size: 0.9375rem; }

  @media (min-width: 700px) {
    .sx-inv__stats { grid-template-columns: repeat(4, 1fr); }
    .sx-inv__gates { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 900px) {
    .sx-inv__cta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 2.5rem 3rem;
    }
    .sx-inv__cta > div { max-width: 34rem; }
  }
</style>
