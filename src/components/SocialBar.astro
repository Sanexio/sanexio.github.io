---

<ul class={`sx-social sx-social--${variant} ${showLabels ? 'sx-social--labelled' : ''}`} aria-label="Sanexio Social Media">
  {socialChannels.map((channel) => (
    <li class="sx-social__item">
      <a href={channel.href} target="_blank" rel="noopener" aria-label={channel.label} title={channel.label}>
        <svg
          class="sx-social__icon"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d={icons[channel.icon]} />
        </svg>
        {channel.badge && <span class="sx-social__badge">{channel.badge}</span>}
        {showLabels && <span class="sx-social__label">{channel.label}</span>}
      </a>
    </li>
  ))}
</ul>

<style>
  .sx-social {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .sx-social__item a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 44px;
    height: 44px;
    border-radius: var(--sx-radius-pill);
    border: 1px solid transparent;
    transition: background-color 200ms ease, border-color 200ms ease, color 200ms ease, transform 200ms ease;
    text-decoration: none;
    position: relative;
  }

  .sx-social--on-brand .sx-social__item a {
    color: rgba(255, 255, 255, 0.8);
    border-color: rgba(255, 255, 255, 0.15);
    background-color: rgba(255, 255, 255, 0.04);
  }

  .sx-social--on-brand .sx-social__item a:hover {
    color: var(--sx-c-data-hi);
    border-color: var(--sx-c-data-hi);
    background-color: rgba(2, 195, 154, 0.08);
    transform: translateY(-2px);
    opacity: 1;
  }

  .sx-social--on-light .sx-social__item a {
    color: var(--sx-c-ink-subtle);
    border-color: var(--sx-c-line);
    background-color: var(--sx-c-surface);
  }

  .sx-social--on-light .sx-social__item a:hover {
    color: var(--sx-c-data);
    border-color: var(--sx-c-data);
    transform: translateY(-2px);
    opacity: 1;
  }

  .sx-social__icon {
    flex-shrink: 0;
  }

  .sx-social__badge {
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    background: var(--sx-c-accent);
    color: var(--color-white);
    padding: 0.125rem 0.4rem;
    border-radius: 4px;
    line-height: 1;
    white-space: nowrap;
  }

  .sx-social--labelled .sx-social__item a {
    width: auto;
    padding-inline: 1rem;
  }

  .sx-social__label {
    font-size: 0.875rem;
    font-weight: 500;
  }
</style>
